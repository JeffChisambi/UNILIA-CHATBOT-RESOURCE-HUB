<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary">

    <!-- Decorative Red and Gold Shapes -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@color/colorAccent"
        android:alpha="0.1"
        android:rotation="45"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="-100dp"
        android:layout_marginTop="-100dp" />

    <View
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@color/colorSecondary"
        android:alpha="0.1"
        android:rotation="45"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="-75dp"
        android:layout_marginBottom="-75dp" />

    <LinearLayout
        android:id="@+id/logo_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- University Logo using the png from drawables -->
        <ImageView
            android:id="@+id/university_logo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/unilialogo"
            android:contentDescription="University of Livingstonia Logo" />

        <TextView
            android:id="@+id/splash_text_unilia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="UNILIA"
            android:textColor="@color/white"
            android:textSize="48sp"
            android:letterSpacing="0.1" />

        <View
            android:layout_width="80dp"
            android:layout_height="4dp"
            android:background="@color/colorAccent"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/splash_text_chatbot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="CHATBOAT"
            android:textColor="@color/colorAccent"
            android:textSize="18sp"
            android:letterSpacing="0.4"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:indeterminateTint="@color/colorAccent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>